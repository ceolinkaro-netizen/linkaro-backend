# Needed to send push notifications (Firebase Console > Project settings >
# Service accounts > Generate new private key). Base64-encode the
# private_key field from that JSON file before pasting it here — many
# hosting dashboards (Render included) corrupt the raw multi-line PEM
# string's "\n" escapes, which breaks OpenSSL's parser. From the downloaded
# JSON: node -e "console.log(Buffer.from(require('./key.json').private_key).toString('base64'))"
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY_BASE64=
